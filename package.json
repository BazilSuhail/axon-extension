{
  "name": "axon-api-client",
  "displayName": "Axon Client",
  "description": "A lightweight API testing extension for VS Code",
  "version": "0.0.2",
  "publisher": "9b44e0ea-284e-6202-b075-e936e0da1bff",
  "license": "MIT",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Testing",
    "Other"
  ],
  "activationEvents": [
    "onView:apiTesterPanel"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/BazilSuhail/axon-extension"
  },
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "api-tester.openPanel",
        "title": "Open API Tester",
        "category": "API Tester",
        "icon": "$(globe)"
      },
      {
        "command": "api-tester.sendRequest",
        "title": "Send Request",
        "category": "API Tester"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "api-tester-panel",
          "title": "API Tester",
          "icon": "$(globe)"
        }
      ]
    },
    "views": {
      "api-tester-panel": [
        {
          "id": "apiTesterPanel",
          "name": "API Tester",
          "type": "webview"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run esbuild-base -- --minify",
    "esbuild-base": "esbuild ./src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node",
    "esbuild": "npm run esbuild-base -- --sourcemap",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/node": "^18.11.9",
    "@types/vscode": "^1.75.0",
    "esbuild": "^0.16.17",
    "typescript": "^4.9.4"
  }
}